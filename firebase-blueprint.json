{
  "entities": {
    "Tenant": {
      "title": "Tenant",
      "description": "A business or restaurant on the platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "logo": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "currency": { "type": "string" },
        "vatRate": { "type": "number" },
        "includeVat": { "type": "boolean" },
        "timezone": { "type": "string" },
        "themeColor": { "type": "string" },
        "expenseCategories": { "type": "array", "items": { "type": "string" } },
        "menuCategories": { "type": "array", "items": { "type": "string" } },
        "customerTokenPrefix": { "type": "string" },
        "nextCustomerToken": { "type": "number" },
        "customerAppEnabled": { "type": "boolean" },
        "isActive": { "type": "boolean" },
        "monthlyBill": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name"]
    },
    "User": {
      "title": "User",
      "description": "A user of the platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "password": { "type": "string" },
        "mobile": { "type": "string" },
        "role": { "type": "string" },
        "avatar": { "type": "string" },
        "permissions": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "password", "role"]
    },
    "MenuItem": {
      "title": "MenuItem",
      "description": "An item on the restaurant menu.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "isAvailable": { "type": "boolean" },
        "stock": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "tenantId", "name", "price", "category"]
    },
    "InventoryItem": {
      "title": "InventoryItem",
      "description": "An item in the restaurant inventory.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "minThreshold": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "tenantId", "name", "quantity", "unit", "minThreshold"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "tokenNumber": { "type": "string" },
        "tableNumber": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "status": { "type": "string" },
        "totalAmount": { "type": "number" },
        "note": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "tenantId", "items", "status", "totalAmount"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "orderId": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "type": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "tenantId", "amount", "method", "type"]
    },
    "Expense": {
      "title": "Expense",
      "description": "A business expense.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "title": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string" },
        "recordedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "tenantId", "title", "amount", "category", "date"]
    },
    "MonthlyBill": {
      "title": "MonthlyBill",
      "description": "A monthly bill for a tenant.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "tenantName": { "type": "string" },
        "month": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "approvedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "tenantId", "tenantName", "month", "amount", "status"]
    }
  },
  "firestore": {
    "/tenants/{tenantId}": { "schema": "Tenant", "description": "Tenant documents." },
    "/users/{userId}": { "schema": "User", "description": "User documents." },
    "/menu_items/{itemId}": { "schema": "MenuItem", "description": "Menu item documents." },
    "/inventory_items/{itemId}": { "schema": "InventoryItem", "description": "Inventory item documents." },
    "/orders/{orderId}": { "schema": "Order", "description": "Order documents." },
    "/transactions/{transactionId}": { "schema": "Transaction", "description": "Transaction documents." },
    "/expenses/{expenseId}": { "schema": "Expense", "description": "Expense documents." },
    "/monthly_bills/{billId}": { "schema": "MonthlyBill", "description": "Monthly bill documents." }
  }
}
