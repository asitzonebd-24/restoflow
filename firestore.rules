// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: tenants
// Fields: id, name, logo, address, mobile, email, isActive, createdAt, etc.
//
// Collection: users
// Fields: id, name, email, mobile, password, role, tenantId, permissions, etc.
//
// Collection: orders
// Fields: id, tenantId, items, totalAmount, status, createdAt, etc.
//
// Collection: menu_items
// Fields: id, tenantId, name, category, price, stock, etc.
//
// Collection: inventory_items
// Fields: id, tenantId, name, quantity, unit, etc.
//
// Collection: transactions
// Fields: id, tenantId, amount, type, date, etc.
//
// Collection: expenses
// Fields: id, tenantId, amount, category, date, etc.
//
// Collection: recipes
// Fields: id, tenantId, menuItemId, ingredients, etc.
//
// Collection: monthly_bills
// Fields: id, tenantId, month, amount, status, createdAt, etc.
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin' ||
         (request.auth.token.email == "asitzonebd@gmail.com" && request.auth.token.email_verified == true));
    }

    function isSuperAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin' ||
         (request.auth.token.email == "asitzonebd@gmail.com" && request.auth.token.email_verified == true));
    }

    function isTenantUser(tenantId) {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId || isSuperAdmin());
    }

    // ===============================================================
    // Match Rules
    // ===============================================================

    // Tenants
    match /tenants/{tenantId} {
      allow read: if true; // Publicly readable for landing pages
      allow write: if isSuperAdmin();
    }

    // Users
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isSuperAdmin() || (isAuthenticated() && request.resource.data.role == 'client');
      allow update: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    // Orders, Menu, Inventory, Transactions, Expenses, Recipes, Monthly Bills
    match /{collectionName}/{docId} {
      allow read: if collectionName in ['orders', 'menu_items', 'inventory_items', 'transactions', 'expenses', 'recipes', 'monthly_bills'] && 
                     (isSuperAdmin() || (isAuthenticated() && resource.data.tenantId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId));
      
      allow create: if collectionName in ['orders', 'menu_items', 'inventory_items', 'transactions', 'expenses', 'recipes', 'monthly_bills'] && 
                      (isSuperAdmin() || (isAuthenticated() && request.resource.data.tenantId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId));
      
      allow update: if collectionName in ['orders', 'menu_items', 'inventory_items', 'transactions', 'expenses', 'recipes', 'monthly_bills'] && 
                      (isSuperAdmin() || (isAuthenticated() && resource.data.tenantId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId));
      
      allow delete: if collectionName in ['orders', 'menu_items', 'inventory_items', 'transactions', 'expenses', 'recipes', 'monthly_bills'] && 
                      isSuperAdmin();
    }

    // Test collection
    match /test/{docId} {
      allow read, write: if true;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
