rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      // For now, since we're using a custom login system, we'll allow writes.
      // In production, you should use Firebase Auth and check request.auth.
      return true;
    }

    function isTenantUser(tenantId) {
      return isAuthenticated() && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId || isAdmin());
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /tenants/{tenantId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if true; // Allow registration
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /menu_items/{itemId} {
      allow read: if true;
      allow write: if isAuthenticated() || isAdmin();
    }

    match /inventory_items/{itemId} {
      allow read: if true;
      allow write: if isAuthenticated() || isAdmin();
    }

    match /orders/{orderId} {
      allow read: if true;
      allow write: if true; // Allow customers to place orders
    }

    match /transactions/{transactionId} {
      allow read: if true;
      allow write: if isAuthenticated() || isAdmin();
    }

    match /expenses/{expenseId} {
      allow read: if true;
      allow write: if isAuthenticated() || isAdmin();
    }

    match /monthly_bills/{billId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
