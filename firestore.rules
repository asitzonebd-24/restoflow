rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc == null ? null : userDoc.data;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && (
        (getUserData() != null && getUserData().role == 'SUPER_ADMIN') || 
        (request.auth.token.email == 'asitzonebd@gmail.com' && request.auth.token.email_verified == true)
      );
    }
    
    function hasTenantAccess(tenantId) {
      let userData = getUserData();
      return isAuthenticated() && (
        isSuperAdmin() || 
        (userData != null && (
          userData.tenantId == tenantId || 
          ('tenantIds' in userData && userData.tenantIds != null && tenantId in userData.tenantIds)
        ))
      );
    }

    // ===============================================================
    // Users Collection
    // ===============================================================
    match /users/{userId} {
      // Anyone can read their own user document
      // Super admins can read all users
      // Users in a tenant can read other users in the same tenant
      allow read: if isAuthenticated() && (
        request.auth.uid == userId || 
        isSuperAdmin() || 
        (getUserData() != null && (
          getUserData().tenantId == resource.data.tenantId ||
          ('tenantIds' in getUserData() && getUserData().tenantIds != null && resource.data.tenantId in getUserData().tenantIds)
        ))
      );
      
      // Only super admins or users with OWNER/MANAGER role in the same tenant can create users
      allow create: if isAuthenticated() && (
        isSuperAdmin() || 
        (getUserData() != null && (getUserData().role == 'OWNER' || getUserData().role == 'MANAGER') && (
          getUserData().tenantId == request.resource.data.tenantId ||
          ('tenantIds' in getUserData() && getUserData().tenantIds != null && request.resource.data.tenantId in getUserData().tenantIds)
        ))
      );
      
      allow update: if isAuthenticated() && (
        isSuperAdmin() || 
        request.auth.uid == userId ||
        (getUserData() != null && (getUserData().role == 'OWNER' || getUserData().role == 'MANAGER') && (
          getUserData().tenantId == resource.data.tenantId ||
          ('tenantIds' in getUserData() && getUserData().tenantIds != null && resource.data.tenantId in getUserData().tenantIds)
        ))
      );

      allow delete: if isAuthenticated() && (
        isSuperAdmin() || 
        (getUserData() != null && (getUserData().role == 'OWNER' || getUserData().role == 'MANAGER') && (
          getUserData().tenantId == resource.data.tenantId ||
          ('tenantIds' in getUserData() && getUserData().tenantIds != null && resource.data.tenantId in getUserData().tenantIds)
        ))
      );
    }

    // ===============================================================
    // Subscription Packages
    // ===============================================================
    match /subscription_packages/{packageId} {
      // Anyone authenticated can read packages to browse them
      allow read: if isAuthenticated();
      // Only super admins can manage packages
      allow write: if isSuperAdmin();
    }

    // ===============================================================
    // Tenants Collection
    // ===============================================================
    match /tenants/{tenantId} {
      // Anyone authenticated can read tenants (needed for login and routing)
      allow read: if isAuthenticated();
      // Only super admins, owners or managers can update their own settings
      allow write: if isSuperAdmin() || (
        isAuthenticated() && 
        getUserData() != null && 
        (getUserData().role == 'OWNER' || getUserData().role == 'MANAGER') && 
        (getUserData().tenantId == tenantId || ('tenantIds' in getUserData() && tenantId in getUserData().tenantIds))
      );
    }

    // ===============================================================
    // Tenant-Scoped Collections
    // ===============================================================
    match /orders/{document} {
      allow read, update, delete: if isAuthenticated() && hasTenantAccess(resource.data.tenantId);
      allow create: if isAuthenticated() && hasTenantAccess(request.resource.data.tenantId);
    }
    match /inventory_items/{document} {
      allow read, update, delete: if isAuthenticated() && hasTenantAccess(resource.data.tenantId);
      allow create: if isAuthenticated() && hasTenantAccess(request.resource.data.tenantId);
    }
    match /menu_items/{document} {
      allow read, update, delete: if isAuthenticated() && hasTenantAccess(resource.data.tenantId);
      allow create: if isAuthenticated() && hasTenantAccess(request.resource.data.tenantId);
    }
    match /transactions/{document} {
      allow read, update, delete: if isAuthenticated() && hasTenantAccess(resource.data.tenantId);
      allow create: if isAuthenticated() && hasTenantAccess(request.resource.data.tenantId);
    }
    match /expenses/{document} {
      allow read, update, delete: if isAuthenticated() && hasTenantAccess(resource.data.tenantId);
      allow create: if isAuthenticated() && hasTenantAccess(request.resource.data.tenantId);
    }
    match /monthly_bills/{document} {
      allow read, update, delete: if isAuthenticated() && hasTenantAccess(resource.data.tenantId);
      allow create: if isAuthenticated() && hasTenantAccess(request.resource.data.tenantId);
    }
    match /recipes/{document} {
      allow read, update, delete: if isAuthenticated() && hasTenantAccess(resource.data.tenantId);
      allow create: if isAuthenticated() && hasTenantAccess(request.resource.data.tenantId);
    }
    match /tables/{document} {
      allow read, update, delete: if isAuthenticated() && hasTenantAccess(resource.data.tenantId);
      allow create: if isAuthenticated() && hasTenantAccess(request.resource.data.tenantId);
    }

    // ===============================================================
    // Print Requests (For Automatic Printer Agent)
    // ===============================================================
    match /print_requests/{document} {
      // Anyone authenticated can create
      allow create: if isAuthenticated() && hasTenantAccess(request.resource.data.tenantId);
      // Allow read/delete for tenant members (including agent if authenticated)
      allow read, delete: if isAuthenticated() && hasTenantAccess(resource.data.tenantId);
    }

    // Default deny for anything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
